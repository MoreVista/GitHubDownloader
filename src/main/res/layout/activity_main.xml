<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:src="@android:drawable/ic_menu_upload" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GitHub リリース ダウンローダー"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GitHubリポジトリのURLを入力してリリースバイナリをダウンロードします"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etRepoUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:hint="https://github.com/owner/repo"
            android:background="@android:drawable/edit_text"
            android:padding="10dp"
            android:textSize="14sp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnGetLatest"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="最新リリースを表示"
            android:textColor="#FFFFFF"
            android:background="#1976D2"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnFetchReleases"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="全リリースを表示"
            android:textColor="#1976D2"
            android:background="@android:color/white"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnShowBookmarks"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="☆ ブックマーク一覧"
            android:textColor="#555555"
            android:background="@android:color/white"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="例:\n• https://github.com/termux/termux-app\n• https://github.com/M66B/NetGuard\n• owner/repo"
            android:textSize="12sp"
            android:textColor="#999999"
            android:padding="10dp"
            android:background="@android:color/white" />

    </LinearLayout>
</ScrollView>
